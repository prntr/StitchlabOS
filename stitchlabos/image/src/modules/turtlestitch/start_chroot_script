#!/usr/bin/env bash
# StitchLabOS - TurtleStitch Module
# Installs TurtleStitch offline web editor

set -e
source /common.sh

echo "=== StitchLabOS: Installing TurtleStitch ==="

# Unpack nginx config and pre-copied TurtleStitch files (copied by CI before chroot)
unpack /filesystem/etc /etc root
unpack /filesystem/home/pi /home/pi pi

# Enable turtlestitch site
ln -sf /etc/nginx/sites-available/turtlestitch /etc/nginx/sites-enabled/turtlestitch

# Create project directory for TurtleStitch files
sudo -u pi mkdir -p /home/pi/printer_data/gcodes/turtlestitch_projects

echo "=== TurtleStitch module complete ==="
