#!/usr/bin/env bash
# StitchLabOS - Klipper Module
# Installs Klipper and Moonraker

set -e
source /common.sh

echo "=== StitchLabOS: Installing Klipper ecosystem ==="

# Install Klipper dependencies
apt-get update
apt-get install -y \
    python3 python3-pip python3-venv \
    git wget curl \
    build-essential libffi-dev libncurses-dev \
    virtualenv python3-dev libopenjp2-7 python3-libgpiod \
    liblmdb-dev libsodium-dev zlib1g-dev libjpeg-dev \
    packagekit wireless-tools
# Note: gcc-arm-none-eabi, avrdude, stm32flash, libnewlib-arm-none-eabi omitted —
# firmware compilation is done on a dev machine, not on the Pi at runtime.

# Create pi user if not exists (should already exist on Pi OS)
id -u pi &>/dev/null || useradd -m -s /bin/bash pi
usermod -aG dialout,tty,video pi

# Clone Klipper (shallow, strip docs content to save space but keep dir)
echo "Cloning Klipper..."
sudo -u pi git clone --depth=1 ${KLIPPER_REPO} ${KLIPPER_DIR}
rm -rf ${KLIPPER_DIR}/docs
mkdir -p ${KLIPPER_DIR}/docs  # Keep dir: Moonraker update_manager validates its existence

# Clone Moonraker (shallow)
echo "Cloning Moonraker..."
sudo -u pi git clone --depth=1 ${MOONRAKER_REPO} ${MOONRAKER_DIR}
rm -rf ${MOONRAKER_DIR}/docs

# Create Klipper virtual environment (use virtualenv, more reliable on Debian)
echo "Setting up Klipper virtualenv..."
sudo -u pi virtualenv -p python3 ${KLIPPY_ENV}
sudo -u pi ${KLIPPY_ENV}/bin/pip install --upgrade pip
sudo -u pi ${KLIPPY_ENV}/bin/pip install -r ${KLIPPER_DIR}/scripts/klippy-requirements.txt

# Create Moonraker virtual environment
echo "Setting up Moonraker virtualenv..."
sudo -u pi virtualenv -p python3 ${MOONRAKER_ENV}
sudo -u pi ${MOONRAKER_ENV}/bin/pip install --upgrade pip
sudo -u pi ${MOONRAKER_ENV}/bin/pip install -r ${MOONRAKER_DIR}/scripts/moonraker-requirements.txt

# Create printer_data directory structure
echo "Creating printer_data directory..."
sudo -u pi mkdir -p ${PRINTER_DATA}/{config,gcodes,logs,comms,certs,systemd,scripts}

# Install systemd service files (from filesystem/)
unpack /filesystem/etc /etc root
unpack /filesystem/home/pi /home/pi pi

# Install Moonraker polkit rules (allows service management, reboot, package install)
mkdir -p /etc/polkit-1/rules.d
cat > /etc/polkit-1/rules.d/moonraker.rules << 'EOF'
polkit.addRule(function(action, subject) {
    if ((action.id == "org.freedesktop.systemd1.manage-units" ||
         action.id == "org.freedesktop.login1.power-off" ||
         action.id == "org.freedesktop.login1.power-off-multiple-sessions" ||
         action.id == "org.freedesktop.login1.reboot" ||
         action.id == "org.freedesktop.login1.reboot-multiple-sessions" ||
         action.id == "org.freedesktop.packagekit.package-install" ||
         action.id == "org.freedesktop.packagekit.system-update") &&
        subject.user == "pi") {
        return polkit.Result.YES;
    }
});
EOF

# Enable services
systemctl daemon-reload
systemctl enable klipper
systemctl enable moonraker

echo "=== Klipper module complete ==="
