#!/usr/bin/env bash
# StitchLabOS - KIAUH Module
# Installs KIAUH as a management tool for updates

set -e
source /common.sh

echo "=== StitchLabOS: Installing KIAUH ==="

# Clone KIAUH (for future updates/management by user)
echo "Cloning KIAUH..."
sudo -u pi git clone ${KIAUH_REPO} ${KIAUH_DIR}

echo "=== KIAUH module complete ==="
echo "Run ~/kiauh/kiauh.sh to manage Klipper components"
